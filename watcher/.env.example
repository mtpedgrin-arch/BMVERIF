# ── Base de datos (misma que Vercel) ──────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── npprteam.shop ─────────────────────────────────────────────────────────────
NPPRTEAM_API_KEY=tu_api_key_de_npprteam
NPPRTEAM_EMAIL=tu_email_en_npprteam
NPPRTEAM_PASSWORD=tu_password_en_npprteam

# ── Wallet TRC20 para fondear npprteam automáticamente ────────────────────────
# Esta wallet debe tener:
#   • USDT TRC20 (para los depósitos a npprteam)
#   • TRX (para fees de red, ~15-30 TRX por tx ≈ $1-2)
# ⚠️ NUNCA compartir esta clave privada con nadie
TRON_PRIVATE_KEY=tu_clave_privada_trc20

# ── Telegram (mismos que Vercel) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_ORDERS_CHAT_ID=tu_chat_id_de_ordenes

# ── Email (Resend API key — misma que Vercel SMTP_PASS) ──────────────────────
SMTP_PASS=re_...
SMTP_FROM=soporte@mail.bmverificada.space

# ── URL del sitio (para botones de retry en Telegram) ────────────────────────
NEXTAUTH_URL=https://bmverificada.space
CRON_SECRET=bmverif_cron_2026

# ── Configuración del watcher ────────────────────────────────────────────────
# Si el saldo en npprteam baja de MIN_BALANCE, recarga aunque pueda cubrir la orden
# → así el fee TRC20 (~$2) se amortiza entre muchas órdenes, no por orden individual
MIN_BALANCE=30

# A cuánto dejar el saldo de npprteam después de recargar
# Ej: con TOPUP_TARGET=100, el fee de $2 se divide entre ~10 órdenes = $0.20/orden
TOPUP_TARGET=100
