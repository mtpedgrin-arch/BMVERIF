# ── Base de datos (misma que Vercel) ──────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── npprteam.shop ─────────────────────────────────────────────────────────────
NPPRTEAM_API_KEY=tu_api_key_de_npprteam
NPPRTEAM_EMAIL=tu_email_en_npprteam
NPPRTEAM_PASSWORD=tu_password_en_npprteam

# ── Red para fondear npprteam automáticamente ─────────────────────────────────
# Opciones: BEP20 (recomendado, fee ~$0.10) o TRC20 (fee ~$1-2)
TOPUP_NETWORK=BEP20

# Si usás BEP20 (BSC): necesitás EVM_PRIVATE_KEY + BNB para fees (~0.001 BNB/tx)
# La dirección de la wallet es la misma que en ETH (0x...)
EVM_PRIVATE_KEY=tu_clave_privada_0x...

# Si preferís TRC20 (TRON): necesitás TRON_PRIVATE_KEY + TRX para fees (~15 TRX/tx)
# TRON_PRIVATE_KEY=tu_clave_privada_tron

# ⚠️ NUNCA compartir claves privadas con nadie ni subirlas a GitHub

# ── Telegram (mismos que Vercel) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_ORDERS_CHAT_ID=tu_chat_id_de_ordenes

# ── Email (Resend API key — misma que Vercel SMTP_PASS) ──────────────────────
SMTP_PASS=re_...
SMTP_FROM=soporte@mail.bmverificada.space

# ── URL del sitio (para botones de retry en Telegram) ────────────────────────
NEXTAUTH_URL=https://bmverificada.space
CRON_SECRET=bmverif_cron_2026

# ── Configuración del watcher ────────────────────────────────────────────────
# Recargar npprteam cuando el saldo baja de MIN_BALANCE
MIN_BALANCE=30
# Cuánto dejar en npprteam después de recargar (amortiza el fee entre muchas órdenes)
TOPUP_TARGET=100
